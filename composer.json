{
  "name": "vitorsreis/sift",
  "description": "Agent-optimized output for PHP tooling",
  "keywords": [
    "php",
    "agent",
    "ai",
    "cli",
    "tooling",
    "phpunit",
    "phpstan"
  ],
  "license": "MIT",
  "type": "library",
  "homepage": "https://github.com/vitorsreis/sift",
  "support": {
    "source": "https://github.com/vitorsreis/sift",
    "issues": "https://github.com/vitorsreis/sift/issues"
  },
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-simplexml": "*",
    "symfony/process": "^7.4 || ^8.0"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "pestphp/pest": "^4.4"
  },
  "autoload": {
    "psr-4": {
      "Sift\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/sift"
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "fmt": "vendor/bin/pint",
    "test": "vendor/bin/pest",
    "test:unit": "vendor/bin/pest --testsuite=Unit",
    "test:integration": "vendor/bin/pest --testsuite=Integration"
  }
}
