{
  "name": "vitorsreis/sift",
  "description": "Agent-optimized output for PHP tooling",
  "keywords": [
    "php",
    "agent",
    "ai",
    "cli",
    "tooling",
    "phpunit",
    "phpstan"
  ],
  "license": "MIT",
  "type": "library",
  "homepage": "https://github.com/vitorsreis/sift",
  "support": {
    "source": "https://github.com/vitorsreis/sift",
    "issues": "https://github.com/vitorsreis/sift/issues"
  },
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-simplexml": "*",
    "symfony/process": "^7.4 || ^8.0"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "pestphp/pest": "^4.4"
  },
  "autoload": {
    "psr-4": {
      "Sift\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/sift"
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "sift": "@php -dxdebug.mode=off bin/sift",
    "lint": "@sift pint",
    "test": "@sift pest --parallel",
    "test:unit": "@test --testsuite=Unit",
    "test:integration": "@test --testsuite=Integration",
    "test:coverage": "@php -dxdebug.mode=coverage bin/sift --pretty pest --parallel --coverage --min=80",
    "build:phar": [
      "Composer\\Config::disableProcessTimeout",
      "@php -d phar.readonly=0 bin/phar"
    ]
  }
}
