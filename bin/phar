#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__.'/../vendor/autoload.php';

$root = dirname(__DIR__);
$distDirectory = $root.DIRECTORY_SEPARATOR.'dist';
$pharPath = $distDirectory.DIRECTORY_SEPARATOR.'sift.phar';
$checksumPath = $pharPath.'.sha256';
$alias = 'sift.phar';

if ((bool) ini_get('phar.readonly')) {
    fwrite(STDERR, "phar.readonly must be disabled to build the PHAR.\n");

    exit(1);
}

prepareDistDirectory($distDirectory);

@unlink($pharPath);
@unlink($checksumPath);

$phar = new Phar($pharPath, 0, $alias);
$phar->startBuffering();

foreach (packageFiles($root) as $localPath => $sourcePath) {
    $phar->addFile($sourcePath, $localPath);
}

$phar->setStub(buildStub($alias));
$phar->setSignatureAlgorithm(Phar::SHA512);
$phar->stopBuffering();

@chmod($pharPath, 0755);

$checksum = hash_file('sha256', $pharPath);
file_put_contents($checksumPath, $checksum.'  sift.phar'.PHP_EOL);

fwrite(STDOUT, json_encode([
    'status' => 'built',
    'phar' => $pharPath,
    'sha256' => $checksumPath,
], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_THROW_ON_ERROR).PHP_EOL);

function prepareDistDirectory(string $distDirectory): void
{
    if (is_dir($distDirectory)) {
        return;
    }

    if (! mkdir($distDirectory, 0777, true) && ! is_dir($distDirectory)) {
        throw new RuntimeException(sprintf('Unable to create dist directory: %s', $distDirectory));
    }
}

/**
 * @return array<string, string>
 */
function packageFiles(string $root): array
{
    $files = [];

    foreach (['src', 'resources'] as $relativePath) {
        $directory = $root.DIRECTORY_SEPARATOR.$relativePath;

        if (! is_dir($directory)) {
            continue;
        }

        foreach (directoryFiles($directory) as $filePath) {
            $localPath = str_replace('\\', '/', substr($filePath, strlen($root) + 1));
            $files[$localPath] = $filePath;
        }
    }

    foreach (['composer.json', 'README.md', 'LICENSE.md'] as $relativePath) {
        $filePath = $root.DIRECTORY_SEPARATOR.$relativePath;

        if (! is_file($filePath)) {
            continue;
        }

        $files[$relativePath] = $filePath;
    }

    ksort($files);

    return $files;
}

function buildStub(string $alias): string
{
    return <<<PHP
#!/usr/bin/env php
<?php

declare(strict_types=1);

Phar::mapPhar('{$alias}');

spl_autoload_register(static function (string \$class): void {
    \$prefix = 'Sift\\\\';

    if (! str_starts_with(\$class, \$prefix)) {
        return;
    }

    \$relativeClass = substr(\$class, strlen(\$prefix));
    \$file = 'phar://{$alias}/src/'.str_replace('\\\\', '/', \$relativeClass).'.php';

    if (is_file(\$file)) {
        require \$file;
    }
});

\$pharFile = Phar::running(false);
\$resolvedPharFile = realpath(\$pharFile);

if (is_string(\$resolvedPharFile)) {
    \$pharFile = \$resolvedPharFile;
} elseif (! str_contains(\$pharFile, DIRECTORY_SEPARATOR) && ! str_contains(\$pharFile, '/')) {
    \$pharFile = getcwd().DIRECTORY_SEPARATOR.\$pharFile;
}

\$pharDirectory = dirname(\$pharFile);
\$workingDirectory = getcwd() ?: \$pharDirectory;
\$autoloadCandidates = [
    \$pharDirectory.'/vendor/autoload.php',
    dirname(\$pharDirectory).'/vendor/autoload.php',
    \$workingDirectory.'/vendor/autoload.php',
    dirname(\$workingDirectory).'/vendor/autoload.php',
];

\$autoloadLoaded = false;

foreach (\$autoloadCandidates as \$autoloadPath) {
    if (! is_file(\$autoloadPath)) {
        continue;
    }

    require \$autoloadPath;
    \$autoloadLoaded = true;

    break;
}

if (! \$autoloadLoaded) {
    fwrite(STDERR, "Unable to locate vendor/autoload.php next to sift.phar or in its parent directory.\\n");

    exit(1);
}

exit(Sift\\Console\\Application::run(\$_SERVER['argv'] ?? []));

__HALT_COMPILER();
PHP;
}

/**
 * @return list<string>
 */
function directoryFiles(string $directory): array
{
    $files = [];
    $iterator = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($directory, RecursiveDirectoryIterator::SKIP_DOTS),
    );

    foreach ($iterator as $item) {
        if (! $item->isFile()) {
            continue;
        }

        $files[] = $item->getPathname();
    }

    sort($files);

    return $files;
}
